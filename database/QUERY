7) Numero di clienti per artista

Molto probabile all'esame

SELECT ar.ArtistId,
       ar.Name,
       COUNT(DISTINCT i.CustomerId) as NumClienti
FROM Artist ar,
     Album al,
     Track t,
     InvoiceLine il,
     Invoice i
WHERE ar.ArtistId=al.ArtistId
AND al.AlbumId=t.AlbumId
AND t.TrackId=il.TrackId
AND il.InvoiceId=i.InvoiceId
GROUP BY ar.ArtistId;
