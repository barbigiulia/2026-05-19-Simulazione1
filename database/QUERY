11) Playlist che contengono un artista
SELECT DISTINCT p.PlaylistId,
                p.Name
FROM Playlist p,
     PlaylistTrack pt,
     Track t,
     Album al
WHERE p.PlaylistId=pt.PlaylistId
AND pt.TrackId=t.TrackId
AND t.AlbumId=al.AlbumId
AND al.ArtistId=?;
