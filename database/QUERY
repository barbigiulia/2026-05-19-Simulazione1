8) Coppie di artisti acquistati dallo stesso cliente

SELECT DISTINCT
A.ArtistId,
B.ArtistId,
I.CustomerId
FROM Invoice I,
     InvoiceLine IL1,
     InvoiceLine IL2,
     Track T1,
     Track T2,
     Album AL1,
     Album AL2
WHERE I.InvoiceId=IL1.InvoiceId
AND I.InvoiceId=IL2.InvoiceId
AND IL1.TrackId=T1.TrackId
AND IL2.TrackId=T2.TrackId
AND T1.AlbumId=AL1.AlbumId
AND T2.AlbumId=AL2.AlbumId
AND AL1.ArtistId<>AL2.ArtistId;
