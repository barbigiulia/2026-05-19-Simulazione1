6) Cliente che ha speso di più
SELECT c.CustomerId,
       c.FirstName,
       c.LastName,
       SUM(i.Total) as Spesa
FROM Customer c,
     Invoice i
WHERE c.CustomerId=i.CustomerId
GROUP BY c.CustomerId
ORDER BY Spesa DESC;
