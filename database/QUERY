9) Brani più acquistati
SELECT t.TrackId,
       t.Name,
       SUM(il.Quantity) as Vendite
FROM Track t,
     InvoiceLine il
WHERE t.TrackId=il.TrackId
GROUP BY t.TrackId
ORDER BY Vendite DESC;
-------------------------------------
10) Album con più brani
SELECT al.AlbumId,
       al.Title,
       COUNT(t.TrackId) as NumBrani
FROM Album al,
     Track t
WHERE al.AlbumId=t.AlbumId
GROUP BY al.AlbumId;
