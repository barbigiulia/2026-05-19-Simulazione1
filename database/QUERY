3) Numero di album per artista
SELECT a.ArtistId,
       a.Name,
       COUNT(al.AlbumId) as NumAlbum
FROM Artist a,
     Album al
WHERE a.ArtistId=al.ArtistId
GROUP BY a.ArtistId
ORDER BY NumAlbum DESC;
-------------------------------------
4) Durata totale dei brani di un artista
SELECT a.Name,
       SUM(t.Milliseconds) as Durata
FROM Artist a,
     Album al,
     Track t
WHERE a.ArtistId=al.ArtistId
AND al.AlbumId=t.AlbumId
GROUP BY a.ArtistId;
