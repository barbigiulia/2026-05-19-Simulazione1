12) Numero di generi per artista
SELECT a.ArtistId,
       a.Name,
       COUNT(DISTINCT t.GenreId)
FROM Artist a,
     Album al,
     Track t
WHERE a.ArtistId=al.ArtistId
AND al.AlbumId=t.AlbumId
GROUP BY a.ArtistId;